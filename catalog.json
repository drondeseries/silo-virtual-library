{
  "plugins": [
    {
      "manifest": {
        "plugin_id": "com.drondeseries.silo-virtual-library",
        "version": "0.4.3",
        "silo_api_version": "v1",
        "capabilities": [
          {
            "type": "http_routes.v1",
            "id": "virtual-playback",
            "display_name": "Virtual Playback",
            "description": "Resolves aiostreams:// virtual paths into short-lived streaming URLs."
          },
          {
            "type": "request_router.v1",
            "id": "virtual-library-requests",
            "display_name": "Virtual Library Requests",
            "description": "Registers home-released media immediately and queues upcoming media for monitoring.",
            "metadata": {
              "connection_defaults": {
                "base_url": "plugin://virtual-library",
                "api_key": "plugin-managed"
              }
            },
            "config_schema": [
              {
                "key": "connection",
                "json_schema": "{\"type\":\"object\",\"properties\":{}}",
                "admin_form": {
                  "fields": []
                }
              }
            ]
          },
          {
            "type": "scheduled_task.v1",
            "id": "monitor-media",
            "display_name": "Monitor Queued Media",
            "description": "Checks queued media for home release and adds newly aired series episodes."
          }
        ],
        "presentation": {
          "display_name": "Silo Virtual Library",
          "summary": "Zero-storage virtual playback backed by dynamic AIOStreams resolution.",
          "description_markdown": "Registers and resolves host-managed `aiostreams://` virtual media through Silo's authenticated plugin control plane, without database credentials or stored media files.",
          "setup_markdown": "Before enabling the request integration, enter the complete secret AIOStreams manifest URL and the numeric IDs of one Movies library and one Series library. Add an optional TMDB token for authoritative worldwide digital/physical release gating. No database URL or media path is required.",
          "homepage_url": "https://github.com/drondeseries/silo-virtual-library",
          "source_url": "https://github.com/drondeseries/silo-virtual-library",
          "support_url": "https://github.com/drondeseries/silo-virtual-library/issues",
          "changelog_url": "https://github.com/drondeseries/silo-virtual-library/releases",
          "publisher_name": "drondeseries",
          "publisher_url": "https://github.com/drondeseries",
          "license_spdx": "NOASSERTION"
        },
        "supported_platforms": [
          {
            "os": "linux",
            "arch": "amd64"
          },
          {
            "os": "linux",
            "arch": "arm64"
          },
          {
            "os": "darwin",
            "arch": "arm64"
          }
        ],
        "global_config_schema": [
          {
            "key": "aiostreams",
            "title": "AIOStreams",
            "description": "Connection to the configured AIOStreams Stremio addon.",
            "json_schema": "{\"type\":\"object\",\"properties\":{\"manifest_url\":{\"type\":\"string\",\"format\":\"uri\"},\"movie_library_id\":{\"type\":\"integer\",\"minimum\":1},\"series_library_id\":{\"type\":\"integer\",\"minimum\":1},\"tmdb_api_key\":{\"type\":\"string\"},\"monitor_file\":{\"type\":\"string\",\"default\":\".silo-virtual-library-monitored.json\"},\"allow_insecure_http\":{\"type\":\"boolean\",\"default\":false}},\"required\":[\"manifest_url\",\"movie_library_id\",\"series_library_id\"],\"additionalProperties\":false}",
            "required": true,
            "admin_form": {
              "fields": [
                {
                  "key": "movie_library_id",
                  "label": "Movies Library ID",
                  "description": "Destination Silo Movies library.",
                  "control": 4,
                  "required": true
                },
                {
                  "key": "series_library_id",
                  "label": "Series Library ID",
                  "description": "Destination Silo Series library.",
                  "control": 4,
                  "required": true
                },
                {
                  "key": "manifest_url",
                  "label": "Manifest URL",
                  "description": "The complete tokenized AIOStreams URL ending in /manifest.json.",
                  "control": 3,
                  "placeholder": "https://…/manifest.json",
                  "required": true,
                  "secret": true
                },
                {
                  "key": "tmdb_api_key",
                  "label": "TMDB API Token",
                  "description": "Optional TMDB v4 token or v3 API key used to distinguish theatrical from home-media releases.",
                  "control": 3,
                  "secret": true
                },
                {
                  "key": "allow_insecure_http",
                  "label": "Allow local HTTP",
                  "description": "Allow plain HTTP only for localhost, .local, single-label Docker/service names, or private IPs. HTTPS remains the default.",
                  "control": 5
                },
                {
                  "key": "monitor_file",
                  "label": "Monitored Queue File",
                  "description": "Writable path used to persist queued media across plugin restarts.",
                  "control": 1,
                  "placeholder": ".silo-virtual-library-monitored.json"
                }
              ],
              "submit_label": "Save AIOStreams connection"
            }
          }
        ]
      },
      "repo_url": "https://github.com/drondeseries/silo-virtual-library",
      "checksums_url": "https://github.com/drondeseries/silo-virtual-library/releases/download/v0.4.3/checksums.txt",
      "binaries": {
        "linux/amd64": {
          "url": "https://github.com/drondeseries/silo-virtual-library/releases/download/v0.4.3/plugin-linux-amd64",
          "checksum": "819bd4e81acf4e86f3674704f3245cc70772e0964b6fb7db4369211b18178aa7"
        },
        "linux/arm64": {
          "url": "https://github.com/drondeseries/silo-virtual-library/releases/download/v0.4.3/plugin-linux-arm64",
          "checksum": "af3af0ce5311a38ebce910e377e47be7f2972a5ad1b73e488f2c20b90b04b142"
        },
        "darwin/arm64": {
          "url": "https://github.com/drondeseries/silo-virtual-library/releases/download/v0.4.3/plugin-darwin-arm64",
          "checksum": "aea88fed8104f10d8691dc335ed64a4158856d0b7a05754c13e16cf864da3c31"
        }
      }
    }
  ]
}
